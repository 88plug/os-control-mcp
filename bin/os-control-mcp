#!/usr/bin/env bash
# os-control-mcp launcher. Pure-stdlib server — shells out to systemctl/etc.
# Resolves Python via scripts/run-python.sh (env override → venv → PATH →
# absolute Homebrew/system fallbacks). ${CLAUDE_PLUGIN_ROOT} is set by Claude
# Code; dirname fallback covers `claude --plugin-dir` dev runs.
set -euo pipefail
ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
RUNNER="${ROOT}/scripts/run-python.sh"

if [ ! -f "$RUNNER" ]; then
  echo "os-control-mcp: run-python.sh missing at $RUNNER" >&2
  exit 1
fi

exec bash "$RUNNER" "$ROOT/server.py"
